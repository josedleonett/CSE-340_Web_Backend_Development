<%- include('partials/header') %>

    <section class="page-header">
      <h2><%= title %></h2>
    </section>

    <% const messages = flash(); %>
    <% Object.keys(messages).forEach(type => { %>
      <% if (messages[type].length > 0) { %>
        <% messages[type].forEach(msg => { %>
          <div class="alert <%= type %>"><%= msg %></div>
        <% }); %>
      <% } %>
    <% }); %>

    <% if (typeof error !== 'undefined' && error) { %>
      <section class="error-message">
        <p><%= error %></p>
      </section>
    <% } %>

    <% if (project) { %>
      <section class="project-details">
        <h3><%= project.title %></h3>
        <p><%= project.description %></p>
        <p><strong>Date:</strong> <%= new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
        <p><strong>Location:</strong> <%= project.location %></p>
        <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>
        <% if (categories && categories.length > 0) { %>
          <p><strong>Categories:</strong>
            <% categories.forEach((cat, index) => { %>
              <a href="/category/<%= cat.category_id %>"><%= cat.category_name %></a><%= index < categories.length - 1 ? ', ' : '' %>
            <% }); %>
          </p>
        <% } %>
      </section>
      <% if (user && user.role_name === 'admin') { %>
      <div class="page-actions">
        <a href="/edit-project/<%= project.project_id %>" class="btn btn-outline">Edit Project</a>
        <a href="/project/<%= project.project_id %>/assign-categories" class="btn btn-outline">Assign Categories</a>
      </div>
      <% } %>
      <% if (isLoggedIn) { %>
        <div class="volunteer-actions">
          <% if (volunteered) { %>
            <p class="volunteer-status">You are volunteering for this project.</p>
            <form method="POST" action="/project/<%= project.project_id %>/remove-volunteer">
              <button type="submit" class="btn btn-outline">Remove Me as Volunteer</button>
            </form>
          <% } else { %>
            <form method="POST" action="/project/<%= project.project_id %>/volunteer">
              <button type="submit" class="btn">Volunteer for This Project</button>
            </form>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <p>Project not found.</p>
    <% } %>

<%- include('partials/footer') %>
