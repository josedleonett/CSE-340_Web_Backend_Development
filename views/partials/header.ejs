<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | CSE 340</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <div class="header-container">
      <h1>Service Project Tracker</h1>
      <nav>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/organizations">Organizations</a></li>
          <li><a href="/projects">Projects</a></li>
          <li><a href="/categories">Categories</a></li>
        </ul>
      </nav>
    </div>
  </header>
  <main>
    <% const flashMessages = flash(); %>
    <% Object.keys(flashMessages).forEach(type => { %>
      <% if (flashMessages[type].length > 0) { %>
        <% flashMessages[type].forEach(msg => { %>
          <div class="alert <%= type %>"><%= msg %></div>
        <% }); %>
      <% } %>
    <% }); %>
