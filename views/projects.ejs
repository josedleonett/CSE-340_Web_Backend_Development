<%- include('partials/header') %>

    <section class="page-header">
      <h2><%= title %></h2>
      <p>Current and upcoming service projects in our community.</p>
    </section>

    <section class="projects-list">
      <div class="project-card">
        <h3>Park Cleanup Day</h3>
        <span class="project-category">Environmental</span>
        <p>Join us for a community cleanup at Central Park. We will be picking up litter, planting flowers, and maintaining trails.</p>
        <p><strong>Date:</strong> March 20, 2026</p>
      </div>
      <div class="project-card">
        <h3>Food Bank Volunteer Day</h3>
        <span class="project-category">Community Service</span>
        <p>Help sort and distribute food to families in need at the local food bank.</p>
        <p><strong>Date:</strong> March 25, 2026</p>
      </div>
      <div class="project-card">
        <h3>Tutoring Program</h3>
        <span class="project-category">Educational</span>
        <p>Volunteer to tutor students in math and reading at the community center.</p>
        <p><strong>Date:</strong> Ongoing - Every Saturday</p>
      </div>
      <div class="project-card">
        <h3>Senior Center Visit</h3>
        <span class="project-category">Health and Wellness</span>
        <p>Spend time with seniors, play games, and provide companionship at the local senior center.</p>
        <p><strong>Date:</strong> April 5, 2026</p>
      </div>
    </section>

<%- include('partials/footer') %>
