<%- include('partials/header') %>

    <section class="page-header">
      <h2><%= title %></h2>
      <p>Browse service projects by category.</p>
    </section>

    <section class="categories-grid">
      <div class="category-card environmental">
        <h3>Environmental</h3>
        <p>Projects focused on conservation, sustainability, and protecting our natural environment. Includes park cleanups, tree planting, and recycling initiatives.</p>
      </div>
      <div class="category-card educational">
        <h3>Educational</h3>
        <p>Learning-focused projects including tutoring, mentoring, literacy programs, and educational workshops for all ages.</p>
      </div>
      <div class="category-card community-service">
        <h3>Community Service</h3>
        <p>General community support projects such as food banks, homeless shelters, community building, and neighborhood improvement.</p>
      </div>
      <div class="category-card health-wellness">
        <h3>Health and Wellness</h3>
        <p>Projects promoting physical and mental health including senior visits, health fairs, fitness programs, and wellness education.</p>
      </div>
    </section>

<%- include('partials/footer') %>
