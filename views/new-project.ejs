<%- include('partials/header') %>

    <section class="page-header">
      <h2><%= title %></h2>
    </section>

    <% const messages = flash(); %>
    <% Object.keys(messages).forEach(type => { %>
      <% if (messages[type].length > 0) { %>
        <% messages[type].forEach(msg => { %>
          <div class="alert <%= type %>"><%= msg %></div>
        <% }); %>
      <% } %>
    <% }); %>

    <div class="form-card">
      <form action="/new-project" method="POST">
        <div class="form-group">
          <label for="title">Project Title</label>
          <input type="text" id="title" name="title" required minlength="3" maxlength="200">
        </div>
        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" required maxlength="1000"></textarea>
        </div>
        <div class="form-group">
          <label for="location">Location</label>
          <input type="text" id="location" name="location" required maxlength="200">
        </div>
        <div class="form-group">
          <label for="date">Date</label>
          <input type="date" id="date" name="date" required>
        </div>
        <div class="form-group">
          <label for="organization_id">Organization</label>
          <select id="organization_id" name="organization_id" required>
            <option value="">-- Select an Organization --</option>
            <% organizations.forEach(org => { %>
              <option value="<%= org.organization_id %>"><%= org.organization_name %></option>
            <% }); %>
          </select>
        </div>
        <button type="submit">Create Project</button>
      </form>
    </div>

<%- include('partials/footer') %>
