<%- include('partials/header') %>

    <section class="page-header">
      <h2><%= title %></h2>
      <p>Community organizations participating in service projects.</p>
    </section>

    <div class="page-actions">
      <a href="/new-organization" class="btn">+ Add Organization</a>
    </div>

    <section class="organizations-grid">
      <% organizations.forEach(org => { %>
      <div class="org-card">
        <img src="/images/org-placeholder.svg" alt="<%= org.organization_name %>">
        <h3><a href="/organization/<%= org.organization_id %>"><%= org.organization_name %></a></h3>
        <p><%= org.mission %></p>
      </div>
      <% }) %>
    </section>

<%- include('partials/footer') %>
